# Required
GRPC_ENDPOINT=https://your-yellowstone-endpoint:443

# Optional auth token
GRPC_X_TOKEN=your-token-here

# Comma-separated account pubkeys to watch in the transaction stream
ACCOUNT_INCLUDE=AccountPubkey1,AccountPubkey2

# Idle threshold in seconds before an alert fires (default: 120)
IDLE_TIMEOUT_SECS=120

# Slack incoming webhook URL — omit to disable Slack alerts entirely
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Required ──────────────────────────────────────────────────────────────────
# Yellowstone gRPC endpoint (no trailing slash)
GRPC_ENDPOINT=https://your-yellowstone-node.com

# ── Account groups (at least one required) ────────────────────────────────────
# Each non-empty group gets its own independent gRPC stream.
# Add as many pubkeys as needed, comma-separated.
ACCOUNT_INCLUDE_1=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
ACCOUNT_INCLUDE_2=DNfuF1L62WWyW3pNakVkyGGFzVVhj4Yr52jSmdTyeBHm,5XVKfruE4Zzeoz3aqBQfFMb5aSscY5nSyc6VwtQwNiid
# ACCOUNT_INCLUDE_3=

# ── Optional ──────────────────────────────────────────────────────────────────
# Bearer token required by some Yellowstone nodes (omit if not needed)
GRPC_X_TOKEN=your_token_here

# Tracing verbosity: error | warn | info | debug | trace
# Use debug to see ping/pong and per-update details
RUST_LOG=info

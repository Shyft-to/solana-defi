# ── Required ──────────────────────────────────────────────────────────────────
# Yellowstone gRPC endpoint (no trailing slash)
GRPC_ENDPOINT=https://your-yellowstone-node.com

# Solana JSON-RPC endpoint used for getBlock calls
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# One or more account pubkeys to verify, comma-separated
TARGET_PUBKEYS=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P,DNfuF1L62WWyW3pNakVkyGGFzVVhj4Yr52jSmdTyeBHm

# ── Optional ──────────────────────────────────────────────────────────────────
# Bearer token required by some Yellowstone nodes (omit if not needed)
GRPC_X_TOKEN=your_token_here

# Commitment level for the Yellowstone gRPC account-update subscription.
# Options: confirmed (default, lower latency) | finalized (safer, ~13s slower)
GRPC_COMMITMENT=confirmed

# Commitment level for JSON-RPC calls (getBlock + getMultipleAccounts).
# Slots are always triggered on SlotFinalized regardless of this setting.
# Options: finalized (default, safe) | confirmed (faster, tiny rollback risk,
#          may not be supported by all RPC providers for getBlock)
RPC_COMMITMENT=finalized

# Tracing verbosity: error | warn | info | debug | trace
RUST_LOG=info

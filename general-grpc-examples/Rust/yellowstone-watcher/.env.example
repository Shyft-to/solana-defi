# ── Required ─────────────────────────────────────────────────────────────────
# Yellowstone gRPC endpoint (no trailing slash)
GRPC_ENDPOINT=https://your-yellowstone-node.com

# Comma-separated list of account public keys to watch
ACCOUNT_INCLUDE=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P

# ── Optional ──────────────────────────────────────────────────────────────────
# Bearer token required by some Yellowstone nodes (omit if not needed)
GRPC_X_TOKEN=your_token_here

# Solana JSON-RPC endpoint for reconciliation
RPC_ENDPOINT=https://rpc.shyft.to/?api_key=YOUR-KEY

# How many slots to wait after confirmation before running reconciliation.
# A small lag gives the RPC time to process the block.
RECONCILE_LAG_SLOTS=5

# Max signatures fetched per getSignaturesForAddress page (ignored when USE_GET_BLOCK=true)
RPC_SIGNATURES_LIMIT=1000

# Set to true to reconcile using getBlock instead of getSignaturesForAddress.
# getBlock fetches the entire block and filters locally to watched accounts.
USE_GET_BLOCK=true

# Slack incoming-webhook URL. When set, missed and extra events are posted to
# Slack in addition to being logged locally. Leave unset to disable.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Tracing verbosity: error | warn | info | debug | trace
# Use RUST_LOG=debug to also see per-slot buffering details.
RUST_LOG=info
